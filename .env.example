# ===========================================
# Kommo API
# ===========================================
# URL base de tu cuenta Kommo (reemplaza con tu subdominio)
KOMMO_BASE_URL=https://TU-SUBDOMINIO.kommo.com

# Token API v4 (obtener desde Configuracion > Integraciones)
KOMMO_ACCESS_TOKEN=tu_token_aqui

# ID de la cuenta (se obtiene de /api/v4/account)
KOMMO_ACCOUNT_ID=

# Client ID de la integracion
KOMMO_CLIENT_ID=

# ===========================================
# Kommo Login (para Selenium - SIN 2FA)
# ===========================================
# Usuario con acceso a Chats, SIN autenticacion de 2 factores
KOMMO_LOGIN_EMAIL=usuario@empresa.com
KOMMO_LOGIN_PASSWORD=tu_password

# ===========================================
# PostgreSQL
# ===========================================
# Connection string completo (Railway, Supabase, local, etc)
DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos

# ===========================================
# Aplicacion
# ===========================================
LOG_LEVEL=INFO
