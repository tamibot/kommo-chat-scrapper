# ═══════════════════════════════════════════════════════════
# KOMMO CHAT SCRAPPER - Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run setup:
#   python scripts/setup_account.py
#   python scripts/validate_setup.py

# ── Kommo API ────────────────────────────────────────────
# URL base de tu cuenta Kommo (reemplaza con tu subdominio)
KOMMO_BASE_URL=https://TU-SUBDOMINIO.kommo.com

# Token API v4
# Obtener: Kommo > Configuracion > Integraciones > Crear integracion privada > Token
# Scopes necesarios: crm, files, notifications
KOMMO_ACCESS_TOKEN=eyJ0eXAiOiJKV1Q...

# ID de cuenta (se obtiene automaticamente con setup_account.py)
KOMMO_ACCOUNT_ID=

# Client ID de la integracion (opcional)
KOMMO_CLIENT_ID=

# ── Login para Scraping ──────────────────────────────────
# IMPORTANTE: Este usuario NO debe tener 2FA (autenticacion de 2 factores)
# Crear un usuario dedicado para el scraper en:
#   Kommo > Configuracion > Usuarios > Nuevo usuario
# Con acceso a: Chats, Leads, Contactos
KOMMO_LOGIN_EMAIL=scraper@empresa.com
KOMMO_LOGIN_PASSWORD=password_seguro

# ── PostgreSQL ───────────────────────────────────────────
# Connection string completo
# Railway: postgresql://postgres:XXX@host.proxy.rlwy.net:PORT/railway
# Supabase: postgresql://postgres:XXX@host.supabase.co:5432/postgres
# Local: postgresql://usuario:password@localhost:5432/kommo_scrapper
DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos

# ── Aplicacion ───────────────────────────────────────────
LOG_LEVEL=INFO
